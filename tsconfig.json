{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "esnext",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src",
    "types.d.ts",
    "types/edge-runtime.d.ts"  // Incluye tu nuevo archivo de declaración de tipos
  ]
}

